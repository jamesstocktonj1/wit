package example:kv-store@2.1.0;

interface types {
  type key = string;

  type value = list<u8>;

  flags consistency {
    strong,
    eventual
  }

  enum error-kind {
    not-found,
    permission-denied,
    internal
  }

  record error {
    kind: error-kind,
    message: string
  }

  record entry {
    key: key,
    value: value,
    version: u64
  }
}

interface store {
  get: func(key: string) -> result<option<list<u8>>, string>;

  set: func(key: string, value: list<u8>) -> result<u64, string>;

  delete: func(key: string) -> result<bool, string>;

  list-keys: func(prefix: string, limit: u32) -> result<list<string>, string>;
}

world kv-client {
  import store;
}

world kv-server {
  export store;
}