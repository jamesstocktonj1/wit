package wasi:cli@0.2.0;

interface stdin {
  record stream-error {
    code: u32,
    message: string
  }
  read: func(len: u64) -> result<list<u8>, stream-error>;
}

interface stdout {
  write: func(buf: list<u8>) -> result<u64, string>;
  flush: func();
}

interface environment {
  get-environment: func() -> list<tuple<string, string>>;
  get-arguments: func() -> list<string>;
  initial-cwd: func() -> option<string>;
}

interface exit {
  enum exit-code {
    success,
    failure
  }
  exit: func(code: exit-code);
}

world command {
  import stdin;
  import environment;
  export stdout;
  export exit;
}

world reactor {
  import stdin;
  import stdout;
  import environment;
}